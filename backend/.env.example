# Runtime bağlantısı — Transaction Pooler (port 6543)
DATABASE_URL=postgresql+psycopg2://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Alembic migration bağlantısı — Direct (port 5432, pooler desteklemiyor)
ALEMBIC_DATABASE_URL=postgresql+psycopg2://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here
